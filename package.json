{
  "name": "the-bee-suite",
  "version": "0.1.0",
  "author": "BrunerDigital",
  "private": true,
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate && npm run lint && npm run typecheck && npm test && next build",
    "start": "next start",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:api": "tsx scripts/api-route-smoke.ts",
    "test:smoke": "tsx scripts/playwright-smoke.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "kidcity:prepare-crm": "python scripts/prepare-kidcity-crm-export.py",
    "kidcity:import-crm": "tsx -r tsconfig-paths/register scripts/import-kidcity-crm.ts",
    "kidcity:create-auth-users": "tsx scripts/create-kidcity-auth-users.ts",
    "kidcity:ensure-executives": "tsx -r tsconfig-paths/register scripts/ensure-kidcity-executives.ts",
    "kidcity:ensure-accounting": "tsx -r tsconfig-paths/register scripts/ensure-kidcity-accounting-user.ts",
    "kidcity:backfill-center-emails": "tsx -r tsconfig-paths/register scripts/backfill-center-notification-emails.ts",
    "kidcity:sync-open-schools": "tsx -r tsconfig-paths/register scripts/sync-kidcity-open-schools.ts",
    "kidcity:cleanup-location-users": "tsx -r tsconfig-paths/register scripts/cleanup-location-user-staff-profiles.ts",
    "kidcity:audit-location-leads": "tsx -r tsconfig-paths/register scripts/audit-location-user-lead-scope.ts",
    "kidcity:audit-director-notifications": "tsx -r tsconfig-paths/register scripts/audit-director-notification-emails.ts",
    "kidcity:import-gmail-inquiries": "tsx -r tsconfig-paths/register scripts/import-gmail-inquiries.ts",
    "demo:seed": "tsx -r tsconfig-paths/register scripts/seed-demo-accounts.ts",
    "tenant:backfill-access": "tsx -r tsconfig-paths/register scripts/backfill-tenant-access-branding.ts",
    "pilot:check": "tsx -r tsconfig-paths/register scripts/pilot-readiness-check.ts",
    "supabase:setup-storage": "tsx -r tsconfig-paths/register scripts/setup-supabase-storage.ts",
    "supabase:migrate-child-media": "tsx -r tsconfig-paths/register scripts/migrate-inline-child-media-to-storage.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.106.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.59.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
