DATABASE_URL="postgresql://postgres:postgres@localhost:5432/the_bee_suite?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth provider placeholders
AUTH_SECRET="replace-before-production"
CRON_SECRET="replace-before-production"
PIN_HASH_SECRET="replace-before-production-with-a-long-random-secret"
DEMO_PASSWORD=""
NEXT_PUBLIC_AUTH_PROVIDER="supabase-or-clerk-or-authjs"
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_CHILD_MEDIA_BUCKET="child-media"
SUPABASE_CHILD_MEDIA_SIGNED_URL_SECONDS="7200"
AUTH_PASSWORD_RESET_REDIRECT_URL="http://localhost:3000/reset-password"

# Integration credentials. Server routes keep secrets out of the browser.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe Connect platform settings. New schools must complete payout onboarding before parent checkout is enabled.
STRIPE_ACCOUNTS_V2_API_VERSION="2026-04-22.dahlia"
STRIPE_APPLICATION_FEE_BPS="0"
# Optional fixed BEE Suite application fee per checkout, in cents.
STRIPE_APPLICATION_FEE_FIXED_CENTS="0"
# Legacy/global parent-paid surcharge. Prefer method-specific processing recovery below for live tuition payments.
STRIPE_PARENT_SURCHARGE_BPS="0"
STRIPE_PARENT_SURCHARGE_FIXED_CENTS="0"
STRIPE_PARENT_SURCHARGE_MAX_CENTS="0"
# Stripe Dashboard payment method configurations used to separate ACH and card checkout flows.
STRIPE_ACH_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_CARD_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_LINK_BANK_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_REQUIRE_PAYMENT_METHOD_CONFIGURATION_FOR_FEES="true"
# Parent-paid processing recovery by payment method. ACH is the preferred no-card-fee option by default.
STRIPE_ACH_PROCESSING_RECOVERY_BPS="0"
STRIPE_ACH_PROCESSING_RECOVERY_FIXED_CENTS="0"
STRIPE_ACH_PROCESSING_RECOVERY_MAX_CENTS="0"
STRIPE_CARD_PROCESSING_RECOVERY_BPS="290"
STRIPE_CARD_PROCESSING_RECOVERY_FIXED_CENTS="30"
STRIPE_CARD_PROCESSING_RECOVERY_GROSS_UP="true"
STRIPE_CARD_PROCESSING_RECOVERY_MAX_CENTS="0"
STRIPE_LINK_BANK_PROCESSING_RECOVERY_BPS="260"
STRIPE_LINK_BANK_PROCESSING_RECOVERY_FIXED_CENTS="30"
STRIPE_LINK_BANK_PROCESSING_RECOVERY_MAX_CENTS="0"
# School-paid BEE Suite tuition payments feature fee retained from successful tuition payouts.
# This replaces a separate monthly fee for the tuition billing/payment module.
STRIPE_PAYMENT_OPS_FEE_BPS="150"
STRIPE_PAYMENT_OPS_FEE_FIXED_CENTS="0"
STRIPE_PAYMENT_OPS_FEE_MAX_CENTS="0"
# Optional explicit waivers. Leave blank for the standard 1.5% fee to apply to all schools.
STRIPE_PAYMENT_OPS_FEE_WAIVED_TENANT_SLUGS=""
STRIPE_PAYMENT_OPS_FEE_WAIVED_BRAND_SLUGS=""
STRIPE_PAYMENT_OPS_FEE_WAIVED_NAMES=""
STRIPE_ALLOW_PLATFORM_ONLY_PAYMENTS="false"
STRIPE_REQUIRE_ACTIVE_CONNECTED_ACCOUNT="true"
STRIPE_CHECKOUT_ON_BEHALF_OF="false"
# Kid City USA Enterprises corporate monthly software invoice.
# Amount is active school user count times the per-user amount.
STRIPE_KIDCITY_ENTERPRISES_CUSTOMER_ID=""
STRIPE_KIDCITY_SOFTWARE_FEE_PER_SCHOOL_USER_CENTS="4900"
STRIPE_KIDCITY_SOFTWARE_INVOICE_DAYS_UNTIL_DUE="15"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_FROM_NUMBER=""
TWILIO_WEBHOOK_BASE_URL="https://thebeesuite.io"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
INQUIRY_NOTIFICATION_EMAILS=""
ONBOARDING_NOTIFICATION_EMAILS=""
INQUIRY_ALLOWED_ORIGINS="https://kidcityusa.com,https://www.kidcityusa.com,https://the-bee-suite-beta.vercel.app"
INQUIRY_DEFAULT_CENTER_ID=""
NEXT_PUBLIC_INQUIRY_TURNSTILE_SITE_KEY=""
INQUIRY_TURNSTILE_SECRET_KEY=""
GOOGLE_SHEETS_WEBHOOK_URL=""
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_SPREADSHEET_URL=""
GOOGLE_SHEETS_SHEET_NAME="Inquiries"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
KIDCITY_FTE_SPREADSHEET_ID=""
KIDCITY_FTE_SPREADSHEET_URL=""
KIDCITY_FTE_CSV_URL=""
# Leave blank to auto-detect a rolling FTE tab such as "FTE Data"; legacy "week N" tabs are only a template fallback.
KIDCITY_FTE_SHEET_NAME=""
KIDCITY_FTE_RANGE=""
FTE_GOOGLE_SHEETS_SPREADSHEET_ID=""
FTE_GOOGLE_SHEETS_SPREADSHEET_URL=""
FTE_GOOGLE_SHEETS_SHEET_NAME="FTE Reports"
FTE_GOOGLE_SHEETS_WEBHOOK_URL=""
KIDCITY_IMPORT_FILE="tmp/kidcity-crm-normalized.json"
KIDCITY_DEFAULT_PASSWORD="set-at-runtime-only"
MAILGUN_API_KEY=""
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=""
META_LEAD_ADS_ACCESS_TOKEN=""
