generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_OWNER
  BRAND_ADMIN
  REGIONAL_MANAGER
  CENTER_DIRECTOR
  ASSISTANT_DIRECTOR
  TEACHER
  BILLING_ADMIN
  PARENT_GUARDIAN
  AUTHORIZED_PICKUP
  READ_ONLY_AUDITOR
}

enum EnrollmentStage {
  NEW_INQUIRY
  CONTACTED
  TOUR_SCHEDULED
  TOUR_COMPLETED
  APPLICATION_SENT
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  DOCUMENTS_PENDING
  DEPOSIT_PENDING
  ENROLLED
  WAITLISTED
  LOST_NOT_A_FIT
}

enum DocumentStatus {
  DRAFT
  REQUESTED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  VOID
  REFUNDED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands                  Brand[]
  organizations           Organization[]
  users                   User[]
  auditLogs               AuditLog[]
  integrations            Integration[]
  integrationCredentials  IntegrationCredential[]
  integrationDeliveries   IntegrationDelivery[]
  calendarEvents          CalendarEvent[]
  campaigns               Campaign[]
  automations             Automation[]
  reviews                 Review[]
  surveys                 Survey[]
  messageTemplates        MessageTemplate[]
  notificationPreferences NotificationPreference[]
  ownerGroups             OwnerGroup[]
  accessGrants            UserAccessGrant[]
  brandAssets             BrandAsset[]
  brandCustomizations     BrandCustomization[]
  deviceSessions          DeviceSession[]
  dataDeletionRequests    DataDeletionRequest[]
}

model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  orgs           Organization[]
  settings       WhiteLabelSettings?
  ownerGroups    OwnerGroup[]
  accessGrants   UserAccessGrant[]
  assets         BrandAsset[]
  customizations BrandCustomization[]
  campaigns      Campaign[]
  automations    Automation[]

  @@unique([tenantId, slug])
}

model Organization {
  id        String   @id @default(cuid())
  tenantId  String
  brandId   String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  brand               Brand?               @relation(fields: [brandId], references: [id])
  centers             Center[]
  users               User[]
  ownerGroups         OwnerGroup[]
  accessGrants        UserAccessGrant[]
  brandCustomizations BrandCustomization[]
}

model Center {
  id               String   @id @default(cuid())
  organizationId   String
  ownerGroupId     String?
  name             String
  crmLocationId    String?
  locationId       String?
  address          String?
  city             String?
  state            String?
  postalCode       String?
  phone            String?
  email            String?
  status           String   @default("active")
  sourceSystem     String?
  externalId       String?
  customFields     Json?
  licensedCapacity Int
  timezone         String   @default("America/New_York")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization             Organization              @relation(fields: [organizationId], references: [id])
  ownerGroup               OwnerGroup?               @relation(fields: [ownerGroupId], references: [id])
  classrooms               Classroom[]
  leads                    Lead[]
  tours                    Tour[]
  staff                    StaffProfile[]
  schedules                StaffSchedule[]
  announcements            Announcement[]
  auditLogs                AuditLog[]
  checkLogs                CheckInOutLog[]
  childLiveLocations       ChildLiveLocation[]
  childLocationTransitions ChildLocationTransition[]
  procareImports           ProcareImportBatch[]
  fteReports               FteReport[]
  accessGrants             UserAccessGrant[]
  brandAssets              BrandAsset[]
  customizations           BrandCustomization[]
  integrationDeliveries    IntegrationDelivery[]
  messageTemplates         MessageTemplate[]
  calendarEvents           CalendarEvent[]
  reviews                  Review[]
  surveys                  Survey[]
  surveyResponses          SurveyResponse[]
  emergencyDrillLogs       EmergencyDrillLog[]
  complianceTasks          ComplianceTask[]
  dataDeletionRequests     DataDeletionRequest[]

  @@index([crmLocationId])
  @@index([locationId])
  @@index([ownerGroupId])
  @@index([state, city])
}

model OwnerGroup {
  id             String   @id @default(cuid())
  tenantId       String
  brandId        String?
  organizationId String?
  name           String
  slug           String
  ownerType      String   @default("franchisee")
  billingEmail   String?
  contactName    String?
  phone          String?
  status         String   @default("active")
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  brand          Brand?               @relation(fields: [brandId], references: [id])
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  centers        Center[]
  accessGrants   UserAccessGrant[]
  assets         BrandAsset[]
  customizations BrandCustomization[]

  @@unique([tenantId, slug])
  @@index([brandId])
  @@index([organizationId])
  @@index([status])
}

model Classroom {
  id           String   @id @default(cuid())
  centerId     String
  name         String
  ageGroup     String
  capacity     Int
  ratioRule    String?
  sourceSystem String?
  externalId   String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  center                       Center                    @relation(fields: [centerId], references: [id])
  children                     Child[]
  staff                        StaffProfile[]
  dailyReports                 DailyReport[]
  incidents                    IncidentReport[]
  attendance                   AttendanceRecord[]
  checkLogs                    CheckInOutLog[]
  media                        ChildMedia[]
  currentChildLocations        ChildLiveLocation[]       @relation("CurrentChildClassroom")
  childLocationTransitionsFrom ChildLocationTransition[] @relation("ChildLocationFromClassroom")
  childLocationTransitionsTo   ChildLocationTransition[] @relation("ChildLocationToClassroom")

  @@index([centerId, sourceSystem, externalId])
}

model User {
  id                String   @id @default(cuid())
  tenantId          String
  organizationId    String?
  email             String   @unique
  name              String
  role              UserRole
  isActive          Boolean  @default(true)
  mustResetPassword Boolean  @default(false)
  sessionVersion    Int      @default(0)
  customFields      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant                    Tenant                    @relation(fields: [tenantId], references: [id])
  organization              Organization?             @relation(fields: [organizationId], references: [id])
  staffProfile              StaffProfile?
  guardians                 Guardian[]
  notes                     Note[]
  messages                  Message[]                 @relation("MessageSender")
  assignedMessages          Message[]                 @relation("MessageAssignee")
  createdMessageTemplates   MessageTemplate[]         @relation("MessageTemplateCreator")
  movedChildLocations       ChildLiveLocation[]       @relation("ChildLocationMovedBy")
  childLocationTransitions  ChildLocationTransition[] @relation("ChildLocationTransitionMovedBy")
  auditLogs                 AuditLog[]
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  medicationLogs            MedicationLog[]
  createdEmergencyDrillLogs EmergencyDrillLog[]       @relation("EmergencyDrillCreatedBy")
  assignedComplianceTasks   ComplianceTask[]          @relation("ComplianceTaskAssignee")
  createdComplianceTasks    ComplianceTask[]          @relation("ComplianceTaskCreator")
  createdCalendarEvents     CalendarEvent[]           @relation("CalendarEventCreatedBy")
  uploadedMedia             ChildMedia[]
  procareImports            ProcareImportBatch[]
  fteReports                FteReport[]               @relation("FteSubmittedBy")
  accessGrants              UserAccessGrant[]
  deviceSessions            DeviceSession[]           @relation("UserDeviceSessions")
  revokedDeviceSessions     DeviceSession[]           @relation("DeviceSessionRevokedBy")
  dataDeletionRequests      DataDeletionRequest[]
}

model UserAccessGrant {
  id             String    @id @default(cuid())
  userId         String
  tenantId       String
  brandId        String?
  organizationId String?
  ownerGroupId   String?
  centerId       String?
  role           UserRole
  scopeType      String
  permissions    Json?
  isActive       Boolean   @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  ownerGroup   OwnerGroup?   @relation(fields: [ownerGroupId], references: [id])
  center       Center?       @relation(fields: [centerId], references: [id])

  @@index([userId, isActive])
  @@index([tenantId, scopeType])
  @@index([brandId])
  @@index([organizationId])
  @@index([ownerGroupId])
  @@index([centerId])
}

model DeviceSession {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  label       String
  deviceType  String    @default("web")
  appMode     String    @default("web")
  userAgent   String?
  ipAddress   String?
  lastSeenAt  DateTime  @default(now())
  revokedAt   DateTime?
  revokedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User   @relation("UserDeviceSessions", fields: [userId], references: [id])
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  revokedBy User?  @relation("DeviceSessionRevokedBy", fields: [revokedById], references: [id])

  @@index([tenantId, lastSeenAt])
  @@index([userId, revokedAt])
  @@index([revokedById])
}

model BrandAsset {
  id           String   @id @default(cuid())
  tenantId     String
  brandId      String?
  ownerGroupId String?
  centerId     String?
  assetType    String
  url          String?
  storageKey   String?
  altText      String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  brand      Brand?      @relation(fields: [brandId], references: [id])
  ownerGroup OwnerGroup? @relation(fields: [ownerGroupId], references: [id])
  center     Center?     @relation(fields: [centerId], references: [id])

  @@index([tenantId, assetType])
  @@index([brandId, assetType])
  @@index([ownerGroupId, assetType])
  @@index([centerId, assetType])
}

model BrandCustomization {
  id                      String   @id @default(cuid())
  tenantId                String
  brandId                 String?
  organizationId          String?
  ownerGroupId            String?
  centerId                String?
  scopeType               String
  brandName               String
  logoUrlPlaceholder      String?
  faviconUrlPlaceholder   String?
  mascotUrlPlaceholder    String?
  primaryColor            String   @default("#f5b51b")
  accentColor             String   @default("#10b981")
  themeMode               String   @default("dark")
  emailSenderPlaceholder  String?
  customDomainPlaceholder String?
  parentPortalName        String?
  loginScreenTitle        String?
  notificationFooterText  String?
  legalFooterText         String?
  termsUrl                String?
  privacyUrl              String?
  customCss               Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  ownerGroup   OwnerGroup?   @relation(fields: [ownerGroupId], references: [id])
  center       Center?       @relation(fields: [centerId], references: [id])

  @@index([tenantId, scopeType])
  @@index([brandId, scopeType])
  @@index([organizationId, scopeType])
  @@index([ownerGroupId, scopeType])
  @@index([centerId, scopeType])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  permissions Permission[]
}

model Permission {
  id       String @id @default(cuid())
  roleId   String
  resource String
  action   String
  scope    String

  role Role @relation(fields: [roleId], references: [id])
}

model Family {
  id           String   @id @default(cuid())
  centerId     String?
  name         String
  address      String?
  billingEmail String?
  notes        String?
  custodyNotes String?
  sourceSystem String?
  externalId   String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guardians         Guardian[]
  children          Child[]
  pickups           AuthorizedPickup[]
  emergencyContacts EmergencyContact[]
  billingAccount    BillingAccount?
  messages          Message[]
  documents         Document[]
  notesList         Note[]
  surveyResponses   SurveyResponse[]
  dataDeletionRequests DataDeletionRequest[]

  @@index([centerId, sourceSystem, externalId])
}

model Guardian {
  id                     String    @id @default(cuid())
  familyId               String
  userId                 String?
  fullName               String
  email                  String?
  phone                  String?
  employer               String?
  relation               String
  preferredCommunication String?
  isBillingContact       Boolean   @default(false)
  checkInPinHash         String?
  checkInPinSetAt        DateTime?
  checkInPinSetById      String?
  sourceSystem           String?
  externalId             String?
  customFields           Json?

  family    Family          @relation(fields: [familyId], references: [id])
  user      User?           @relation(fields: [userId], references: [id])
  checkLogs CheckInOutLog[]
  dataDeletionRequests DataDeletionRequest[]

  @@index([checkInPinHash])
  @@index([sourceSystem, externalId])
}

model Child {
  id                   String    @id @default(cuid())
  familyId             String
  classroomId          String?
  fullName             String
  preferredName        String?
  dateOfBirth          DateTime
  ageGroup             String
  enrollmentStatus     String
  startDate            DateTime?
  schedule             Json?
  photoVideoPermission Boolean   @default(false)
  fieldTripPermission  Boolean   @default(false)
  napNotes             String?
  feedingNotes         String?
  pottyNotes           String?
  developmentalNotes   String?
  sourceSystem         String?
  externalId           String?
  customFields         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  family              Family                    @relation(fields: [familyId], references: [id])
  classroom           Classroom?                @relation(fields: [classroomId], references: [id])
  medicalNotes        ChildMedicalNote[]
  allergies           Allergy[]
  enrollments         Enrollment[]
  attendance          AttendanceRecord[]
  checkLogs           CheckInOutLog[]
  dailyReports        DailyReport[]
  incidents           IncidentReport[]
  documents           Document[]
  media               ChildMedia[]
  medicationLogs      MedicationLog[]
  liveLocation        ChildLiveLocation?
  locationTransitions ChildLocationTransition[]

  @@index([sourceSystem, externalId])
}

model ChildLiveLocation {
  id                 String   @id @default(cuid())
  childId            String   @unique
  centerId           String?
  currentClassroomId String?
  areaName           String?
  status             String   @default("in_classroom")
  reason             String?
  movedAt            DateTime @default(now())
  movedById          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  child            Child      @relation(fields: [childId], references: [id])
  center           Center?    @relation(fields: [centerId], references: [id])
  currentClassroom Classroom? @relation("CurrentChildClassroom", fields: [currentClassroomId], references: [id])
  movedBy          User?      @relation("ChildLocationMovedBy", fields: [movedById], references: [id])

  @@index([centerId, currentClassroomId])
  @@index([movedAt])
}

model ChildLocationTransition {
  id              String   @id @default(cuid())
  childId         String
  centerId        String?
  fromClassroomId String?
  toClassroomId   String?
  fromAreaName    String?
  toAreaName      String?
  reason          String?
  movedById       String?
  movedAt         DateTime @default(now())
  createdAt       DateTime @default(now())
  clientActionId  String?  @unique

  child         Child      @relation(fields: [childId], references: [id])
  center        Center?    @relation(fields: [centerId], references: [id])
  fromClassroom Classroom? @relation("ChildLocationFromClassroom", fields: [fromClassroomId], references: [id])
  toClassroom   Classroom? @relation("ChildLocationToClassroom", fields: [toClassroomId], references: [id])
  movedBy       User?      @relation("ChildLocationTransitionMovedBy", fields: [movedById], references: [id])

  @@index([childId, movedAt])
  @@index([centerId, movedAt])
  @@index([toClassroomId, movedAt])
}

model AuthorizedPickup {
  id                String  @id @default(cuid())
  familyId          String
  fullName          String
  phone             String?
  relation          String?
  verificationNotes String?
  sourceSystem      String?
  externalId        String?
  customFields      Json?

  family Family @relation(fields: [familyId], references: [id])

  @@index([sourceSystem, externalId])
}

model EmergencyContact {
  id           String  @id @default(cuid())
  familyId     String
  fullName     String
  phone        String
  relation     String
  sourceSystem String?
  externalId   String?
  customFields Json?

  family Family @relation(fields: [familyId], references: [id])

  @@index([sourceSystem, externalId])
}

model ChildMedicalNote {
  id         String   @id @default(cuid())
  childId    String
  category   String
  note       String
  restricted Boolean  @default(true)
  createdAt  DateTime @default(now())

  child Child @relation(fields: [childId], references: [id])
}

model Allergy {
  id         String  @id @default(cuid())
  childId    String
  allergen   String
  severity   String
  actionPlan String?

  child Child @relation(fields: [childId], references: [id])
}

model Enrollment {
  id               String          @id @default(cuid())
  childId          String
  leadId           String?
  stage            EnrollmentStage
  desiredStartDate DateTime?
  depositDueCents  Int             @default(0)
  depositPaidCents Int             @default(0)
  checklist        Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  child Child @relation(fields: [childId], references: [id])
  lead  Lead? @relation(fields: [leadId], references: [id])
}

model EnrollmentPipelineStage {
  id         String  @id @default(cuid())
  name       String
  sortOrder  Int
  isTerminal Boolean @default(false)
}

model Lead {
  id               String          @id @default(cuid())
  centerId         String
  externalId       String?
  familyName       String
  parentFirstName  String?
  parentLastName   String?
  email            String?
  phone            String?
  childName        String?
  leadSource       String?
  ageGroupInterest String?
  desiredStartDate DateTime?
  programInterest  String?
  stage            EnrollmentStage @default(NEW_INQUIRY)
  score            Int             @default(0)
  status           String          @default("open")
  customFields     Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  center                Center                @relation(fields: [centerId], references: [id])
  tours                 Tour[]
  enrollments           Enrollment[]
  tasks                 Task[]
  notes                 Note[]
  tags                  Tag[]                 @relation("LeadTags")
  integrationDeliveries IntegrationDelivery[]

  @@unique([centerId, externalId])
  @@index([centerId, stage])
  @@index([email])
  @@index([createdAt])
}

model Tour {
  id       String   @id @default(cuid())
  centerId String
  leadId   String?
  startsAt DateTime
  status   String
  notes    String?

  center Center @relation(fields: [centerId], references: [id])
  lead   Lead?  @relation(fields: [leadId], references: [id])
}

model WaitlistEntry {
  id               String    @id @default(cuid())
  childName        String
  familyName       String
  ageGroup         String
  desiredStartDate DateTime?
  priority         Int       @default(0)
  status           String    @default("waiting")
  notes            String?
}

model Task {
  id         String    @id @default(cuid())
  leadId     String?
  title      String
  dueAt      DateTime?
  status     String    @default("open")
  assignedTo String?

  lead Lead? @relation(fields: [leadId], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  userId     String?
  leadId     String?
  familyId   String?
  body       String
  restricted Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  lead   Lead?   @relation(fields: [leadId], references: [id])
  family Family? @relation(fields: [familyId], references: [id])
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  leads Lead[] @relation("LeadTags")
}

model CustomField {
  id        String  @id @default(cuid())
  entity    String
  key       String
  label     String
  fieldType String
  required  Boolean @default(false)
}

model Message {
  id               String    @id @default(cuid())
  familyId         String?
  senderId         String?
  assignedToId     String?
  templateId       String?
  replyToMessageId String?
  threadKey        String?
  subject          String?
  body             String
  channel          String
  priority         String    @default("normal")
  sentiment        String?
  metadata         Json?
  readAt           DateTime?
  createdAt        DateTime  @default(now())

  family                Family?               @relation(fields: [familyId], references: [id])
  sender                User?                 @relation("MessageSender", fields: [senderId], references: [id])
  assignedTo            User?                 @relation("MessageAssignee", fields: [assignedToId], references: [id])
  template              MessageTemplate?      @relation(fields: [templateId], references: [id])
  replyTo               Message?              @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies               Message[]             @relation("MessageReplies")
  integrationDeliveries IntegrationDelivery[]

  @@index([familyId, createdAt])
  @@index([threadKey, createdAt])
  @@index([assignedToId, readAt, createdAt])
}

model MessageTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  centerId    String?
  name        String
  subject     String
  body        String
  category    String   @default("general")
  channel     String   @default("portal")
  mergeFields Json?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  center    Center?   @relation(fields: [centerId], references: [id])
  createdBy User?     @relation("MessageTemplateCreator", fields: [createdById], references: [id])
  messages  Message[]

  @@unique([tenantId, centerId, name])
  @@index([tenantId, centerId, isActive])
}

model Announcement {
  id       String    @id @default(cuid())
  centerId String?
  title    String
  body     String
  audience Json?
  status   String    @default("draft")
  sendAt   DateTime?

  center Center? @relation(fields: [centerId], references: [id])
}

model Campaign {
  id          String    @id @default(cuid())
  tenantId    String?
  brandId     String?
  name        String
  type        String
  subject     String?
  body        String?
  templateKey String?
  audience    Json?
  status      String
  scheduledAt DateTime?
  sentAt      DateTime?
  metrics     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  brand  Brand?  @relation(fields: [brandId], references: [id])

  @@index([tenantId, status, scheduledAt])
  @@index([brandId, status, scheduledAt])
}

model Automation {
  id        String  @id @default(cuid())
  tenantId  String?
  brandId   String?
  name      String
  trigger   String
  condition Json?
  action    Json
  delay     String?
  status    String

  tenant Tenant?         @relation(fields: [tenantId], references: [id])
  brand  Brand?          @relation(fields: [brandId], references: [id])
  runs   AutomationRun[]

  @@index([tenantId, status])
}

model AutomationRun {
  id           String   @id @default(cuid())
  automationId String
  status       String
  logs         Json?
  createdAt    DateTime @default(now())

  automation Automation @relation(fields: [automationId], references: [id])
}

model Form {
  id     String @id @default(cuid())
  name   String
  type   String
  schema Json
  status String @default("active")

  submissions FormSubmission[]
}

model FormSubmission {
  id                   String         @id @default(cuid())
  formId               String
  familyId             String?
  status               DocumentStatus
  data                 Json
  signaturePlaceholder Boolean        @default(false)
  submittedAt          DateTime?

  form Form @relation(fields: [formId], references: [id])
}

model Document {
  id         String         @id @default(cuid())
  familyId   String?
  childId    String?
  name       String
  type       String
  status     DocumentStatus
  expiresAt  DateTime?
  storageKey String?
  restricted Boolean        @default(false)
  createdAt  DateTime       @default(now())

