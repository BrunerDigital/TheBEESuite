generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_OWNER
  BRAND_ADMIN
  REGIONAL_MANAGER
  CENTER_DIRECTOR
  ASSISTANT_DIRECTOR
  TEACHER
  BILLING_ADMIN
  PARENT_GUARDIAN
  AUTHORIZED_PICKUP
  READ_ONLY_AUDITOR
}

enum EnrollmentStage {
  NEW_INQUIRY
  CONTACTED
  TOUR_SCHEDULED
  TOUR_COMPLETED
  APPLICATION_SENT
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  DOCUMENTS_PENDING
  DEPOSIT_PENDING
  ENROLLED
  WAITLISTED
  LOST_NOT_A_FIT
}

enum DocumentStatus {
  DRAFT
  REQUESTED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  VOID
  REFUNDED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands                Brand[]
  organizations         Organization[]
  users                 User[]
  auditLogs             AuditLog[]
  integrations          Integration[]
  integrationDeliveries IntegrationDelivery[]
  ownerGroups           OwnerGroup[]
  accessGrants          UserAccessGrant[]
  brandAssets           BrandAsset[]
  brandCustomizations   BrandCustomization[]
}

model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  orgs           Organization[]
  settings       WhiteLabelSettings?
  ownerGroups    OwnerGroup[]
  accessGrants   UserAccessGrant[]
  assets         BrandAsset[]
  customizations BrandCustomization[]
  campaigns      Campaign[]
  automations    Automation[]

  @@unique([tenantId, slug])
}

model Organization {
  id        String   @id @default(cuid())
  tenantId  String
  brandId   String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  brand               Brand?               @relation(fields: [brandId], references: [id])
  centers             Center[]
  users               User[]
  ownerGroups         OwnerGroup[]
  accessGrants        UserAccessGrant[]
  brandCustomizations BrandCustomization[]
}

model Center {
  id               String   @id @default(cuid())
  organizationId   String
  ownerGroupId     String?
  name             String
  crmLocationId    String?
  locationId       String?
  address          String?
  city             String?
  state            String?
  postalCode       String?
  phone            String?
  email            String?
  status           String   @default("active")
  sourceSystem     String?
  externalId       String?
  customFields     Json?
  licensedCapacity Int
  timezone         String   @default("America/New_York")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization          Organization          @relation(fields: [organizationId], references: [id])
  ownerGroup            OwnerGroup?           @relation(fields: [ownerGroupId], references: [id])
  classrooms            Classroom[]
  leads                 Lead[]
  tours                 Tour[]
  staff                 StaffProfile[]
  schedules             StaffSchedule[]
  announcements         Announcement[]
  auditLogs             AuditLog[]
  checkLogs             CheckInOutLog[]
  procareImports        ProcareImportBatch[]
  fteReports            FteReport[]
  accessGrants          UserAccessGrant[]
  brandAssets           BrandAsset[]
  customizations        BrandCustomization[]
  integrationDeliveries IntegrationDelivery[]

  @@index([crmLocationId])
  @@index([locationId])
  @@index([ownerGroupId])
  @@index([state, city])
}

model OwnerGroup {
  id             String   @id @default(cuid())
  tenantId       String
  brandId        String?
  organizationId String?
  name           String
  slug           String
  ownerType      String   @default("franchisee")
  billingEmail   String?
  contactName    String?
  phone          String?
  status         String   @default("active")
  customFields   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  brand          Brand?               @relation(fields: [brandId], references: [id])
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  centers        Center[]
  accessGrants   UserAccessGrant[]
  assets         BrandAsset[]
  customizations BrandCustomization[]

  @@unique([tenantId, slug])
  @@index([brandId])
  @@index([organizationId])
  @@index([status])
}

model Classroom {
  id           String   @id @default(cuid())
  centerId     String
  name         String
  ageGroup     String
  capacity     Int
  ratioRule    String?
  sourceSystem String?
  externalId   String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  center       Center             @relation(fields: [centerId], references: [id])
  children     Child[]
  staff        StaffProfile[]
  dailyReports DailyReport[]
  incidents    IncidentReport[]
  attendance   AttendanceRecord[]
  checkLogs    CheckInOutLog[]
  media        ChildMedia[]

  @@index([centerId, sourceSystem, externalId])
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  organizationId String?
  email          String   @unique
  name           String
  role           UserRole
  isActive       Boolean  @default(true)
  mustResetPassword Boolean @default(false)
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  organization   Organization?        @relation(fields: [organizationId], references: [id])
  staffProfile   StaffProfile?
  guardians      Guardian[]
  notes          Note[]
  messages       Message[]            @relation("MessageSender")
  auditLogs      AuditLog[]
  notifications  Notification[]
  uploadedMedia  ChildMedia[]
  procareImports ProcareImportBatch[]
  fteReports     FteReport[]          @relation("FteSubmittedBy")
  accessGrants   UserAccessGrant[]
}

model UserAccessGrant {
  id             String    @id @default(cuid())
  userId         String
  tenantId       String
  brandId        String?
  organizationId String?
  ownerGroupId   String?
  centerId       String?
  role           UserRole
  scopeType      String
  permissions    Json?
  isActive       Boolean   @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  ownerGroup   OwnerGroup?   @relation(fields: [ownerGroupId], references: [id])
  center       Center?       @relation(fields: [centerId], references: [id])

  @@index([userId, isActive])
  @@index([tenantId, scopeType])
  @@index([brandId])
  @@index([organizationId])
  @@index([ownerGroupId])
  @@index([centerId])
}

model BrandAsset {
  id           String   @id @default(cuid())
  tenantId     String
  brandId      String?
  ownerGroupId String?
  centerId     String?
  assetType    String
  url          String?
  storageKey   String?
  altText      String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  brand      Brand?      @relation(fields: [brandId], references: [id])
  ownerGroup OwnerGroup? @relation(fields: [ownerGroupId], references: [id])
  center     Center?     @relation(fields: [centerId], references: [id])

  @@index([tenantId, assetType])
  @@index([brandId, assetType])
  @@index([ownerGroupId, assetType])
  @@index([centerId, assetType])
}

model BrandCustomization {
  id                      String   @id @default(cuid())
  tenantId                String
  brandId                 String?
  organizationId          String?
  ownerGroupId            String?
  centerId                String?
  scopeType               String
  brandName               String
  logoUrlPlaceholder      String?
  faviconUrlPlaceholder   String?
  mascotUrlPlaceholder    String?
  primaryColor            String   @default("#f5b51b")
  accentColor             String   @default("#10b981")
  themeMode               String   @default("dark")
  emailSenderPlaceholder  String?
  customDomainPlaceholder String?
  parentPortalName        String?
  loginScreenTitle        String?
  notificationFooterText  String?
  legalFooterText         String?
  termsUrl                String?
  privacyUrl              String?
  customCss               Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  ownerGroup   OwnerGroup?   @relation(fields: [ownerGroupId], references: [id])
  center       Center?       @relation(fields: [centerId], references: [id])

  @@index([tenantId, scopeType])
  @@index([brandId, scopeType])
  @@index([organizationId, scopeType])
  @@index([ownerGroupId, scopeType])
  @@index([centerId, scopeType])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  permissions Permission[]
}

model Permission {
  id       String @id @default(cuid())
  roleId   String
  resource String
  action   String
  scope    String

  role Role @relation(fields: [roleId], references: [id])
}

model Family {
  id           String   @id @default(cuid())
  centerId     String?
  name         String
  address      String?
  billingEmail String?
  notes        String?
  custodyNotes String?
  sourceSystem String?
  externalId   String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guardians         Guardian[]
  children          Child[]
  pickups           AuthorizedPickup[]
  emergencyContacts EmergencyContact[]
  billingAccount    BillingAccount?
  messages          Message[]
  documents         Document[]
  notesList         Note[]

  @@index([centerId, sourceSystem, externalId])
}

model Guardian {
  id                     String    @id @default(cuid())
  familyId               String
  userId                 String?
  fullName               String
  email                  String?
  phone                  String?
  employer               String?
  relation               String
  preferredCommunication String?
  isBillingContact       Boolean   @default(false)
  checkInPinHash         String?
  checkInPinSetAt        DateTime?
  checkInPinSetById      String?
  sourceSystem           String?
  externalId             String?
  customFields           Json?

  family    Family          @relation(fields: [familyId], references: [id])
  user      User?           @relation(fields: [userId], references: [id])
  checkLogs CheckInOutLog[]

  @@index([checkInPinHash])
  @@index([sourceSystem, externalId])
}

model Child {
  id                   String    @id @default(cuid())
  familyId             String
  classroomId          String?
  fullName             String
  preferredName        String?
  dateOfBirth          DateTime
  ageGroup             String
  enrollmentStatus     String
  startDate            DateTime?
  schedule             Json?
  photoVideoPermission Boolean   @default(false)
  fieldTripPermission  Boolean   @default(false)
  napNotes             String?
  feedingNotes         String?
  pottyNotes           String?
  developmentalNotes   String?
  sourceSystem         String?
  externalId           String?
  customFields         Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  family       Family             @relation(fields: [familyId], references: [id])
  classroom    Classroom?         @relation(fields: [classroomId], references: [id])
  medicalNotes ChildMedicalNote[]
  allergies    Allergy[]
  enrollments  Enrollment[]
  attendance   AttendanceRecord[]
  checkLogs    CheckInOutLog[]
  dailyReports DailyReport[]
  incidents    IncidentReport[]
  documents    Document[]
  media        ChildMedia[]

  @@index([sourceSystem, externalId])
}

model AuthorizedPickup {
  id                String  @id @default(cuid())
  familyId          String
  fullName          String
  phone             String?
  relation          String?
  verificationNotes String?
  sourceSystem      String?
  externalId        String?
  customFields      Json?

  family Family @relation(fields: [familyId], references: [id])

  @@index([sourceSystem, externalId])
}

model EmergencyContact {
  id           String  @id @default(cuid())
  familyId     String
  fullName     String
  phone        String
  relation     String
  sourceSystem String?
  externalId   String?
  customFields Json?

  family Family @relation(fields: [familyId], references: [id])

  @@index([sourceSystem, externalId])
}

model ChildMedicalNote {
  id         String   @id @default(cuid())
  childId    String
  category   String
  note       String
  restricted Boolean  @default(true)
  createdAt  DateTime @default(now())

  child Child @relation(fields: [childId], references: [id])
}

model Allergy {
  id         String  @id @default(cuid())
  childId    String
  allergen   String
  severity   String
  actionPlan String?

  child Child @relation(fields: [childId], references: [id])
}

model Enrollment {
  id               String          @id @default(cuid())
  childId          String
  leadId           String?
  stage            EnrollmentStage
  desiredStartDate DateTime?
  depositDueCents  Int             @default(0)
  depositPaidCents Int             @default(0)
  checklist        Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  child Child @relation(fields: [childId], references: [id])
  lead  Lead? @relation(fields: [leadId], references: [id])
}

model EnrollmentPipelineStage {
  id         String  @id @default(cuid())
  name       String
  sortOrder  Int
  isTerminal Boolean @default(false)
}

model Lead {
  id               String          @id @default(cuid())
  centerId         String
  externalId       String?
  familyName       String
  parentFirstName  String?
  parentLastName   String?
  email            String?
  phone            String?
  childName        String?
  leadSource       String?
  ageGroupInterest String?
  desiredStartDate DateTime?
  programInterest  String?
  stage            EnrollmentStage @default(NEW_INQUIRY)
  score            Int             @default(0)
  status           String          @default("open")
  customFields     Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  center                Center                @relation(fields: [centerId], references: [id])
  tours                 Tour[]
  enrollments           Enrollment[]
  tasks                 Task[]
  notes                 Note[]
  tags                  Tag[]                 @relation("LeadTags")
  integrationDeliveries IntegrationDelivery[]

  @@unique([centerId, externalId])
  @@index([centerId, stage])
  @@index([email])
  @@index([createdAt])
}

model Tour {
  id       String   @id @default(cuid())
  centerId String
  leadId   String?
  startsAt DateTime
  status   String
  notes    String?

  center Center @relation(fields: [centerId], references: [id])
  lead   Lead?  @relation(fields: [leadId], references: [id])
}

model WaitlistEntry {
  id               String    @id @default(cuid())
  childName        String
  familyName       String
  ageGroup         String
  desiredStartDate DateTime?
  priority         Int       @default(0)
  status           String    @default("waiting")
  notes            String?
}

model Task {
  id         String    @id @default(cuid())
  leadId     String?
  title      String
  dueAt      DateTime?
  status     String    @default("open")
  assignedTo String?

  lead Lead? @relation(fields: [leadId], references: [id])
}

model Note {
  id         String   @id @default(cuid())
  userId     String?
  leadId     String?
  familyId   String?
  body       String
  restricted Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  lead   Lead?   @relation(fields: [leadId], references: [id])
  family Family? @relation(fields: [familyId], references: [id])
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  leads Lead[] @relation("LeadTags")
}

model CustomField {
  id        String  @id @default(cuid())
  entity    String
  key       String
  label     String
  fieldType String
  required  Boolean @default(false)
}

model Message {
  id        String    @id @default(cuid())
  familyId  String?
  senderId  String?
  subject   String?
  body      String
  channel   String
  priority  String    @default("normal")
  sentiment String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  family Family? @relation(fields: [familyId], references: [id])
  sender User?   @relation("MessageSender", fields: [senderId], references: [id])
}

model Announcement {
  id       String    @id @default(cuid())
  centerId String?
  title    String
  body     String
  audience Json?
  status   String    @default("draft")
  sendAt   DateTime?

  center Center? @relation(fields: [centerId], references: [id])
}

model Campaign {
  id       String  @id @default(cuid())
  brandId  String?
  name     String
  type     String
  audience Json?
  status   String
  metrics  Json?

  brand Brand? @relation(fields: [brandId], references: [id])
}

model Automation {
  id        String  @id @default(cuid())
  brandId   String?
  name      String
  trigger   String
  condition Json?
  action    Json
  delay     String?
  status    String

  brand Brand?          @relation(fields: [brandId], references: [id])
  runs  AutomationRun[]
}

model AutomationRun {
  id           String   @id @default(cuid())
  automationId String
  status       String
  logs         Json?
  createdAt    DateTime @default(now())

  automation Automation @relation(fields: [automationId], references: [id])
}

model Form {
  id     String @id @default(cuid())
  name   String
  type   String
  schema Json
  status String @default("active")

  submissions FormSubmission[]
}

model FormSubmission {
  id                   String         @id @default(cuid())
  formId               String
  familyId             String?
  status               DocumentStatus
  data                 Json
  signaturePlaceholder Boolean        @default(false)
  submittedAt          DateTime?

  form Form @relation(fields: [formId], references: [id])
}

model Document {
  id         String         @id @default(cuid())
  familyId   String?
  childId    String?
  name       String
  type       String
  status     DocumentStatus
  expiresAt  DateTime?
  storageKey String?
  restricted Boolean        @default(false)
  createdAt  DateTime       @default(now())

  family Family? @relation(fields: [familyId], references: [id])
  child  Child?  @relation(fields: [childId], references: [id])
}

model AttendanceRecord {
  id            String   @id @default(cuid())
  childId       String?
  classroomId   String?
  date          DateTime
  status        String
  absenceReason String?
  sourceSystem  String?
  externalId    String?
  metadata      Json?

  child     Child?     @relation(fields: [childId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])

  @@index([sourceSystem, externalId])
  @@index([classroomId, date])
}

model CheckInOutLog {
  id                   String   @id @default(cuid())
  childId              String
  centerId             String?
  classroomId          String?
  guardianId           String?
  type                 String
  occurredAt           DateTime
  pickupName           String?
  signaturePlaceholder Boolean  @default(false)
  verificationStatus   String?
  pinVerified          Boolean  @default(false)
  notes                String?
  sourceSystem         String?
  externalId           String?
  metadata             Json?

  child     Child      @relation(fields: [childId], references: [id])
  center    Center?    @relation(fields: [centerId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])
  guardian  Guardian?  @relation(fields: [guardianId], references: [id])

  @@index([centerId, occurredAt])
  @@index([childId, occurredAt])
  @@index([guardianId, occurredAt])
  @@index([sourceSystem, externalId])
}

model DailyReport {
  id             String    @id @default(cuid())
  childId        String
  classroomId    String?
  date           DateTime
  mood           String?
  teacherNote    String?
  suppliesNeeded String?
  sentAt         DateTime?

  child      Child            @relation(fields: [childId], references: [id])
  classroom  Classroom?       @relation(fields: [classroomId], references: [id])
  meals      Meal[]
  naps       Nap[]
  diapers    DiaperPottyLog[]
  activities ActivityLog[]
  media      ChildMedia[]
}

model ChildMedia {
  id                String   @id @default(cuid())
  childId           String
  classroomId       String?
  uploadedById      String?
  dailyReportId     String?
  url               String
  storageKey        String?
  caption           String?
  mediaType         String   @default("photo")
  status            String   @default("shared")
  sharedWithParents Boolean  @default(true)
  takenAt           DateTime @default(now())
  createdAt         DateTime @default(now())

  child       Child        @relation(fields: [childId], references: [id])
  classroom   Classroom?   @relation(fields: [classroomId], references: [id])
  uploadedBy  User?        @relation(fields: [uploadedById], references: [id])
  dailyReport DailyReport? @relation(fields: [dailyReportId], references: [id])

  @@index([childId, createdAt])
  @@index([classroomId, createdAt])
}

model Meal {
  id            String  @id @default(cuid())
  dailyReportId String
  mealType      String
  food          String
  amount        String?

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id])
}

model Nap {
  id            String    @id @default(cuid())
  dailyReportId String
  startsAt      DateTime
  endsAt        DateTime?

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id])
}

model DiaperPottyLog {
  id            String   @id @default(cuid())
  dailyReportId String
  type          String
  occurredAt    DateTime
  notes         String?

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id])
}

model ActivityLog {
  id            String  @id @default(cuid())
  dailyReportId String
  title         String
  notes         String?

  dailyReport DailyReport @relation(fields: [dailyReportId], references: [id])
}

model IncidentReport {
  id                         String    @id @default(cuid())
  childId                    String
  classroomId                String?
  staffMember                String
  occurredAt                 DateTime
  type                       String
  description                String
  actionTaken                String
  parentNotified             Boolean   @default(false)
  parentAcknowledgedAt       DateTime?
  photoAttachmentPlaceholder Boolean   @default(false)
  adminReviewStatus          String    @default("pending")
  followUpTasks              Json?

  child     Child      @relation(fields: [childId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])
}

model StaffProfile {
  id                          String  @id @default(cuid())
  userId                      String  @unique
  centerId                    String
  classroomId                 String?
  title                       String
  phone                       String?
  backgroundCheckStatus       String?
  performanceNotesPlaceholder String?
  ptoAvailabilityPlaceholder  Json?
  sourceSystem                String?
  externalId                  String?
  customFields                Json?

  user           User            @relation(fields: [userId], references: [id])
  center         Center          @relation(fields: [centerId], references: [id])
  classroom      Classroom?      @relation(fields: [classroomId], references: [id])
  schedules      StaffSchedule[]
  certifications Certification[]

  @@index([centerId, sourceSystem, externalId])
}

model StaffSchedule {
  id       String   @id @default(cuid())
  staffId  String
  centerId String
  startsAt DateTime
  endsAt   DateTime
  status   String

  staff  StaffProfile @relation(fields: [staffId], references: [id])
  center Center       @relation(fields: [centerId], references: [id])
}

model Certification {
  id        String    @id @default(cuid())
  staffId   String
  name      String
  status    String
  expiresAt DateTime?

  staff StaffProfile @relation(fields: [staffId], references: [id])
}

model BillingAccount {
  id                 String    @id @default(cuid())
  familyId           String    @unique
  balanceCents       Int       @default(0)
  autopayPlaceholder Boolean   @default(false)
  ledgerSyncedAt     DateTime?
  sourceSystem       String?
  externalId         String?
  customFields       Json?

  family        Family        @relation(fields: [familyId], references: [id])
  invoices      Invoice[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]

  @@index([sourceSystem, externalId])
}

model Invoice {
  id               String        @id @default(cuid())
  billingAccountId String
  number           String        @unique
  status           PaymentStatus
  dueDate          DateTime
  totalCents       Int
  sourceSystem     String?
  externalId       String?
  customFields     Json?
  createdAt        DateTime      @default(now())

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id])
  items          InvoiceItem[]
  ledgerEntries  LedgerEntry[]

  @@index([sourceSystem, externalId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  amountCents Int

  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id                    String        @id @default(cuid())
  billingAccountId      String
  amountCents           Int
  status                PaymentStatus
  provider              String        @default("stripe_mock")
  externalIdPlaceholder String?
  customFields          Json?
  paidAt                DateTime?

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id])
  ledgerEntries  LedgerEntry[]
}

model LedgerEntry {
  id                String   @id @default(cuid())
  billingAccountId  String
  invoiceId         String?
  paymentId         String?
  type              String
  description       String
  amountCents       Int
  balanceAfterCents Int?
  effectiveAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  sourceSystem      String?
  externalId        String?
  metadata          Json?

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id])
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id])
  payment        Payment?       @relation(fields: [paymentId], references: [id])

  @@unique([sourceSystem, externalId])
  @@index([billingAccountId, effectiveAt])
  @@index([invoiceId])
  @@index([paymentId])
}

model Product {
  id          String @id @default(cuid())
  name        String
  type        String
  amountCents Int

  invoiceItems InvoiceItem[]
}

model TuitionPlan {
  id          String @id @default(cuid())
  name        String
  ageGroup    String
  cadence     String
  amountCents Int
}

model SubscriptionPlaceholder {
  id     String @id @default(cuid())
  name   String
  plan   String
  status String
}

model Review {
  id                           String  @id @default(cuid())
  source                       String
  rating                       Int
  body                         String?
  responseDraft                String?
  approvedForPublicTestimonial Boolean @default(false)
}

model Survey {
  id      String @id @default(cuid())
  name    String
  type    String
  status  String
  results Json?
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  title     String
  body      String
  type      String
  priority  String    @default("normal")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  centerId   String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  center Center? @relation(fields: [centerId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
}

model Integration {
  id                String    @id @default(cuid())
  tenantId          String
  provider          String
  status            String
  configPlaceholder Json?
  lastSyncAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model IntegrationDelivery {
  id            String    @id @default(cuid())
  tenantId      String
  centerId      String?
  leadId        String?
  provider      String
  purpose       String
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5)
  payload       Json
  lastResult    Json?
  lastError     String?
  nextAttemptAt DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  center Center? @relation(fields: [centerId], references: [id])
  lead   Lead?   @relation(fields: [leadId], references: [id])

  @@index([status, nextAttemptAt])
  @@index([tenantId, provider, createdAt])
  @@index([centerId, createdAt])
  @@index([leadId])
}

model StripeWebhookEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  dedupeKey   String    @unique
  type        String
  objectId    String?
  livemode    Boolean?
  status      String
  payload     Json?
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, createdAt])
  @@index([objectId])
}

model ProcareImportBatch {
  id           String   @id @default(cuid())
  centerId     String
  uploadedById String?
  filename     String
  status       String   @default("completed")
  summary      Json?
  createdAt    DateTime @default(now())

  center     Center             @relation(fields: [centerId], references: [id])
  uploadedBy User?              @relation(fields: [uploadedById], references: [id])
  rows       ProcareImportRow[]

  @@index([centerId, createdAt])
}

model ProcareImportRow {
  id              String  @id @default(cuid())
  batchId         String
  rowNumber       Int
  status          String
  message         String?
  rawData         Json
  createdFamilyId String?
  createdChildId  String?

  batch ProcareImportBatch @relation(fields: [batchId], references: [id])

  @@index([batchId, status])
}

model FteReport {
  id             String    @id @default(cuid())
  centerId       String
  submittedById  String?
  weekStart      DateTime
  weekEnd        DateTime?
  enrolledCount  Int       @default(0)
  fullTimeCount  Int       @default(0)
  partTimeCount  Int       @default(0)
  fteCount       Float     @default(0)
  infants        Int       @default(0)
  toddlers       Int       @default(0)
  twos           Int       @default(0)
  preschool      Int       @default(0)
  preK           Int       @default(0)
  schoolAge      Int       @default(0)
  notes          String?
  status         String    @default("submitted")
  source         String    @default("manual")
  sourceMetadata Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  center      Center @relation(fields: [centerId], references: [id])
  submittedBy User?  @relation("FteSubmittedBy", fields: [submittedById], references: [id])

  @@unique([centerId, weekStart])
  @@index([weekStart])
  @@index([status])
}

model WhiteLabelSettings {
  id                      String  @id @default(cuid())
  brandId                 String  @unique
  brandName               String
  logoUrlPlaceholder      String?
  faviconUrlPlaceholder   String?
  primaryColor            String
  accentColor             String
  themeMode               String
  emailSenderPlaceholder  String?
  customDomainPlaceholder String?
  legalFooterText         String?
  termsUrl                String?
  privacyUrl              String?

  brand Brand @relation(fields: [brandId], references: [id])
}

model AiSummary {
  id             String   @id @default(cuid())
  scope          String
  scopeId        String?
  title          String
  body           String
  requiresReview Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model AiSuggestion {
  id            String   @id @default(cuid())
  type          String
  promptContext Json?
  suggestion    String
  status        String   @default("pending_review")
  guardrailNote String
  createdAt     DateTime @default(now())
}
