{
  "npm.packageManager": "npm",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "files.associations": {
    ".env*": "dotenv"
  },
  "files.exclude": {
    ".next": true
  },
  "search.exclude": {
    ".next": true,
    "node_modules": true,
    "logs": true,
    ".vercel": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/logs/**": true
  }
}
