# Integration credentials. Server routes keep secrets out of the browser.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Pin Stripe API requests. The default follows the June 24, 2026 preview docs used by the app.
STRIPE_API_VERSION="2026-06-24.preview"
# Stripe Connect platform settings. New schools must complete payout onboarding before parent checkout is enabled.
STRIPE_ACCOUNTS_V2_API_VERSION="2026-06-24.preview"
STRIPE_APPLICATION_FEE_BPS="0"
# Optional fixed BEE Suite application fee per checkout, in cents.
STRIPE_APPLICATION_FEE_FIXED_CENTS="0"
# Legacy/global parent-paid surcharge. Prefer method-specific processing recovery below for live tuition payments.
STRIPE_PARENT_SURCHARGE_BPS="0"
STRIPE_PARENT_SURCHARGE_FIXED_CENTS="0"
STRIPE_PARENT_SURCHARGE_MAX_CENTS="0"
# Stripe Dashboard payment method configurations used to separate ACH and card checkout flows.
STRIPE_ACH_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_CARD_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_LINK_BANK_PAYMENT_METHOD_CONFIGURATION_ID=""
STRIPE_REQUIRE_PAYMENT_METHOD_CONFIGURATION_FOR_FEES="true"
STRIPE_PARENT_PROCESSING_RECOVERY_APPROVED="false"
# Parent-paid processing recovery by payment method. ACH and instant bank are always parent-fee-free.
STRIPE_CARD_PROCESSING_RECOVERY_BPS="290"
STRIPE_CARD_PROCESSING_RECOVERY_FIXED_CENTS="30"
STRIPE_CARD_PROCESSING_RECOVERY_GROSS_UP="true"
STRIPE_CARD_PROCESSING_RECOVERY_MAX_CENTS="0"
# Instant bank verification uses the ACH no-parent-fee policy.
# School-paid BEE Suite tuition payments feature fee retained from successful tuition payouts.
# This replaces a separate monthly fee for the tuition billing/payment module.
STRIPE_PAYMENT_OPS_FEE_BPS="150"
STRIPE_PAYMENT_OPS_FEE_FIXED_CENTS="0"
STRIPE_PAYMENT_OPS_FEE_MAX_CENTS="0"
# Optional explicit waivers. Leave blank for the standard 1.5% fee to apply to all schools.
STRIPE_PAYMENT_OPS_FEE_WAIVED_TENANT_SLUGS=""
STRIPE_PAYMENT_OPS_FEE_WAIVED_BRAND_SLUGS=""
STRIPE_PAYMENT_OPS_FEE_WAIVED_NAMES=""
STRIPE_ALLOW_PLATFORM_ONLY_PAYMENTS="false"
STRIPE_REQUIRE_ACTIVE_CONNECTED_ACCOUNT="true"
STRIPE_CHECKOUT_ON_BEHALF_OF="false"
# Kid City USA Enterprises corporate monthly software invoice.
# Amount is active school user count times the per-user amount.
STRIPE_KIDCITY_ENTERPRISES_CUSTOMER_ID=""
STRIPE_KIDCITY_SOFTWARE_FEE_PER_SCHOOL_USER_CENTS="4900"
STRIPE_KIDCITY_SOFTWARE_INVOICE_DAYS_UNTIL_DUE="15"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_FROM_NUMBER=""
TWILIO_WEBHOOK_BASE_URL="https://thebeesuite.io"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
SENDGRID_EVENT_WEBHOOK_VERIFICATION_KEY=""
# Fail closed by default. Enable only when shared sender authentication, branding,
