{
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run vercel-build",
  "crons": [
    {
      "path": "/api/cron/fte-reminders",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/fte-reminders",
      "schedule": "0 12,13,17,18 * * 5"
    },
    {
      "path": "/api/cron/integration-retries",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/tuition-billing",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/document-expiration-reminders",
      "schedule": "45 14 * * *"
    },
    {
      "path": "/api/cron/payment-dunning",
      "schedule": "0 15 * * *"
    }
  ]
}
